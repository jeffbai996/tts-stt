# ─── TTS (text-to-speech) ───────────────────────────────
# Uses ElevenLabs API for natural voice synthesis.

# Required: ElevenLabs API key (get from https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_api_key_here

# Voice ID for TTS output. Defaults to Scott (Scottish male, m99arlGCGHhMIOwh8bGc).
# Other examples: Chris (American, iP95p4xoKVk53GoZ742B), Liam (English, xrExE9yKIg1WjnnlVkGp)
# Full list: python list_voices.py
TTS_VOICE_ID=m99arlGCGHhMIOwh8bGc

# ElevenLabs model ID. Defaults to eleven_v3 (recommended for quality).
TTS_MODEL=eleven_v3

# Accent tag prepended to text for v3 models. Set to "" to disable.
# Examples: [Scottish accent], [American accent], [Australian accent]
TTS_ACCENT_TAG=[Scottish accent]

# Playback speed multiplier applied via ffmpeg. 1.0 = normal, 1.1 = 10% faster.
TTS_SPEED=1.05

# ─── STT (speech-to-text) ───────────────────────────────
# Requires `whisper` CLI on PATH.
# Install: brew install openai-whisper (Mac) or pip3 install openai-whisper (Linux)

# Model size — trade speed vs accuracy. base is 0.76x real-time on Apple Silicon.
STT_MODEL=base

# Language code (e.g. en, zh, ja). Skips auto-detect. Set per bot:
#   MacClaude:  en
#   Claudsson:  zh
#   Fraggy:     en
STT_LANGUAGE=en

# Where intermediate whisper files land. Default: <repo>/transcripts/
# (gitignored; cleaned up after each run). Uncomment to override.
# STT_OUTPUT_DIR=/custom/path/
